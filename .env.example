# ----------------------------------------
# Server Configuration
# ----------------------------------------
PORT=3000

# ----------------------------------------
# Cloudinary Configuration
# Get these values from https://console.cloudinary.com
# ----------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----------------------------------------
# Temporary File Storage
# ----------------------------------------
TEMP_DIRECTORY=./temp

# ----------------------------------------
# Limits
# ----------------------------------------
MAX_FILE_SIZE_MB=500
