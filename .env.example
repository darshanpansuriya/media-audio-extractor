# ----------------------------------------
# Server Configuration
# ----------------------------------------
PORT=3000

# ----------------------------------------
# Cloudinary Configuration
# Get these values from https://console.cloudinary.com
# ----------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----------------------------------------
# Temporary File Storage
# ----------------------------------------
TEMP_DIRECTORY=./temp

# ----------------------------------------
# Limits
# ----------------------------------------
MAX_FILE_SIZE_MB=500

# ----------------------------------------
# yt-dlp extraction (YouTube anti-bot)
# ----------------------------------------
# YouTube blocks datacenter/server IPs with "Sign in to confirm you're not a
# bot". To get past it, export cookies from a logged-in browser as a
# Netscape-format cookies.txt and point this at the file. Relative paths are
# resolved from the app's working directory; an absolute path is safest under
# pm2. See: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
YTDLP_COOKIES_FILE=

# Optional fallback: force a specific YouTube player client when you cannot use
# cookies. Try one of: web_safari, android, ios, tv, mweb. Leave empty to let
# yt-dlp choose.
YTDLP_PLAYER_CLIENT=
